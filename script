/**
 * Lógica de Interação, Acessibilidade e Responsividade do Leitor
 * Tema: Agro forte, Futuro sustentável (2026)
 */

document.addEventListener('DOMContentLoaded', () => {
    
    // ==========================================
    // SELETORES GERAIS
    // ==========================================
    const body = document.body;
    const menuAcessibilidade = document.getElementById('menu-acessibilidade');
    const btnMoverMenu = document.getElementById('btn-mover-menu');
    const btnAumentarFonte = document.getElementById('btn-aumentar-fonte');
    const btnDiminuirFonte = document.getElementById('btn-diminuir-fonte');
    const btnAlternarTema = document.getElementById('btn-alternar-tema');
    const btnLerVoz = document.getElementById('btn-ler-voz');
    
    const formInscricao = document.getElementById('form-inscricao');
    const formComentario = document.getElementById('form-comentario');
    const textoComentario = document.getElementById('texto-comentario');
    const listaComentarios = document.getElementById('lista-comentarios');
    const conteudoPrincipal = document.getElementById('conteudo-principal');

    // Variavel de controle do tamanho da fonte (escala em rem)
    let tamanhoFonteAtual = 100; // representado em porcentagem (%)
    let falando = false;
    let sinteseVoz = window.speechSynthesis;
    let utterance = null;

    // ==========================================
    // FUNCIONALIDADE: ACESSIBILIDADE FLUTUANTE
    // ==========================================

    // 1. Mover Menu para Esquerda / Direita
    btnMoverMenu.addEventListener('click', () => {
        menuAcessibilidade.classList.toggle('direita');
    });

    // 2. Controle de tamanho do Texto (Aumentar / Diminuir)
    btnAumentarFonte.addEventListener('click', () => {
        if (tamanhoFonteAtual < 140) { // Limite máximo seguro
            tamanhoFonteAtual += 10;
            aplicarTamanhoFonte();
        }
    });

    btnDiminuirFonte.addEventListener('click', () => {
        if (tamanhoFonteAtual > 80) { // Limite mínimo seguro
            tamanhoFonteAtual -= 10;
            aplicarTamanhoFonte();
        }
    });

    function aplicarTamanhoFonte() {
        body.style.fontSize = `${tamanhoFonteAtual}%`;
    }

    // 3. Alternar Tema (Modo Claro / Escuro)
    btnAlternarTema.addEventListener('click', () => {
        body.classList.toggle('modo-escuro');
        
        // Acessibilidade: Atualiza estado de aria para leitores de tela se necessário
        const isEscuro = body.classList.contains('modo-escuro');
        btnAlternarTema.setAttribute('aria-label', isEscuro ? "Mudar para modo claro" : "Mudar para modo escuro");
    });

    // 4. Leitura por Voz (SpeechSynthesis API) - Apenas Conteúdo Principal
    btnLerVoz.addEventListener('click', () => {
        if (!sinteseVoz) {
            alert("Desculpe, seu navegador não suporta leitura por voz nativa.");
            return;
        }

        if (falando) {
            sinteseVoz.cancel();
            falando = false;
            btnLerVoz.textContent = "🔊";
            btnLerVoz.setAttribute('aria-label', "Ouvir conteúdo principal por voz");
        } else {
            // Captura apenas o texto corrido contido dentro da tag principal <main>
            const textoParaLer = conteudoPrincipal.innerText || conteudoPrincipal.textContent;
            
            utterance = new SpeechSynthesisUtterance(textoParaLer);
            utterance.lang = 'pt-BR';
            utterance.rate = 1.0; // Velocidade natural da fala

            utterance.onend = () => {
                falando = false;
                btnLerVoz.textContent = "🔊";
            };

            utterance.onerror = () => {
                falando = false;
                btnLerVoz.textContent = "🔊";
            };

            btnLerVoz.textContent = "🛑";
            btnLerVoz.setAttribute('aria-label', "Parar leitura de voz");
            sinteseVoz.speak(utterance);
            falando = true;
        }
    });


    // ==========================================
    // FUNCIONALIDADE: FORMULÁRIO DE INSCRIÇÃO
    // ==========================================
    formInscricao.addEventListener('submit', (e) => {
        e.preventDefault();
        const inputEmail = document.getElementById('email-inscricao');
        
        if (inputEmail.value.trim() === "" || !inputEmail.validity.valid) {
            alert("Por favor, insira um e-mail válido para a inscrição científica.");
            return;
        }

        alert(`Inscrição realizada com sucesso para: ${inputEmail.value}\nBem-vindo à rede de inovação agroecológica do Brasil!`);
        inputEmail.value = "";
    });


    // ==========================================
    // INTERAÇÃO COM O LEITOR: COMENTÁRIOS
    // ==========================================
    formComentario.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const texto = textoComentario.value.trim();
        if (texto === "") return;

        // Criando elemento de comentário estruturado de forma harmônica
        const novoComentario = document.createElement('div');
        novoComentario.classList.add('item-comentario');
        
        // Pegando data atual estruturada
        const dataAtual = new Date().toLocaleDateString('pt-BR', {
            day: '2-digit',
            month: '2-digit',
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
        });

        novoComentario.innerHTML = `
            <p style="font-size: 0.85rem; color: var(--cor-magenta); font-weight: bold; margin-bottom: 5px;">Leitor Participante • ${dataAtual}</p>
            <p style="font-size: 1rem; line-height: 1.5;">${escaparHTML(texto)}</p>
        `;

        // Insere o novo comentário no topo da lista
        listaComentarios.insertBefore(novoComentario, listaComentarios.firstChild);
        
        // Limpa o formulário e foca novamente por usabilidade
        textoComentario.value = "";
        alert("Obrigado por compartilhar sua opinião técnica!");
    });

    // Segurança: Função auxiliar simples para prevenir XSS nos comentários injetados
    function escaparHTML(string) {
        return string
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }
});